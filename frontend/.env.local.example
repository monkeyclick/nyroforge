# AWS Configuration
NEXT_PUBLIC_AWS_REGION=us-west-2
NEXT_PUBLIC_USER_POOL_ID=us-west-2_XXXXXXXXX
NEXT_PUBLIC_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-west-2.amazonaws.com/api
NEXT_PUBLIC_ADMIN_API_ENDPOINT=https://yyyyyyyyyy.execute-api.us-west-2.amazonaws.com/prod

# Local Development (optional)
# Set to 'true' to enable admin mode for all users in local dev
NEXT_PUBLIC_LOCAL_ADMIN_MODE=false

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the values with your actual AWS configuration
# 3. Get these values from:
#    - AWS Cognito User Pool (for USER_POOL_ID and USER_POOL_CLIENT_ID)
#    - API Gateway (for API_ENDPOINT from WorkstationApi stack output)
#    - API Gateway (for ADMIN_API_ENDPOINT from WorkstationAdminApi stack output)
#    - Or from the CDK deployment outputs
# 4. For local development, you can set NEXT_PUBLIC_LOCAL_ADMIN_MODE=true
#    to enable admin access without backend configuration
#
# Note: ADMIN_API_ENDPOINT is used for EC2 discovery/import and other admin-specific
# operations that were moved to a separate API Gateway to avoid CloudFormation resource limits.