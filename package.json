{
  "name": "nyroforge",
  "version": "1.0.0",
  "description": "Serverless AWS application for managing virtual GPU editing workstations",
  "homepage": "https://nyroforge.com",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:lambdas": "node scripts/build-lambdas.js",
    "prebuild": "npm run build:lambdas",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/jest": "^29.5.11",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.117.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-cdk/aws-amplify-alpha": "^2.117.0-alpha.0",
    "@aws-sdk/client-cloudwatch": "^3.478.0",
    "@aws-sdk/client-cost-explorer": "^3.478.0",
    "@aws-sdk/client-dynamodb": "^3.478.0",
    "@aws-sdk/client-ec2": "^3.478.0",
    "@aws-sdk/client-secrets-manager": "^3.478.0",
    "@aws-sdk/client-ssm": "^3.478.0",
    "@aws-sdk/lib-dynamodb": "^3.478.0",
    "@aws-sdk/util-dynamodb": "^3.478.0",
    "aws-cdk-lib": "^2.117.0",
    "aws-jwt-verify": "^5.1.1",
    "constructs": "^10.3.0",
    "uuid": "^9.0.0"
  },
  "keywords": [
    "aws",
    "serverless",
    "media",
    "workstation",
    "ec2",
    "cdk"
  ],
  "author": "NyroForge (https://nyroforge.com)",
  "license": "MIT"
}
